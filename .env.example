# 실제 값이 채워진 .env 파일은 절대 git에 커밋하지 않는다.
# 이 파일은 필요한 환경변수 목록만 보여주는 템플릿이다.

# 서버
PORT=3000
NODE_ENV=development

# DB (MySQL/MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=
DB_NAME=tiny_secondhand

# 세션
SESSION_SECRET=

# 기타
BCRYPT_SALT_ROUNDS=12

# 레이트리밋 (생략 시 운영 환경 기준 기본값 사용: 로그인 10/10분, 회원가입 20/1시간, 송금 10/1분)
# 자동화 테스트처럼 짧은 시간에 다수의 계정/요청을 만들어야 하는 환경에서만 값을 높여서 사용한다.
# LOGIN_RATE_LIMIT_MAX=10
# REGISTER_RATE_LIMIT_MAX=20
# TRANSFER_RATE_LIMIT_MAX=10
