<%# 마이페이지 (회원정보 조회/수정, 비밀번호 변경) %>
<%- include('../partials/header') %>
<section class="auth-form">
  <h1>마이페이지</h1>
  <p>아이디: <%= user.username %></p>
  <p>이메일: <%= user.email %></p>
  <p>등급: <%= user.role === 'ADMIN' ? '관리자' : '일반회원' %></p>
  <p>보유 잔액: <%= Number(user.balance).toLocaleString('ko-KR') %>원</p>
  <p>가입일: <%= new Date(user.created_at).toLocaleDateString('ko-KR') %></p>
</section>

<section class="auth-form">
  <h2>소개글 수정</h2>

  <% if (bioUpdated) { %>
    <p class="success-message">소개글이 수정되었습니다.</p>
  <% } %>
  <% if (bioErrors && bioErrors.length) { %>
    <ul class="error-list">
      <% bioErrors.forEach(function(msg) { %><li><%= msg %></li><% }); %>
    </ul>
  <% } %>

  <form action="/users/me/bio" method="POST" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label for="bio">소개글</label>
    <textarea id="bio" name="bio" maxlength="500" rows="4"><%= bioValue %></textarea>

    <button type="submit">저장</button>
  </form>
</section>

<section class="auth-form">
  <h2>비밀번호 변경</h2>

  <% if (passwordUpdated) { %>
    <p class="success-message">비밀번호가 변경되었습니다.</p>
  <% } %>
  <% if (passwordErrors && passwordErrors.length) { %>
    <ul class="error-list">
      <% passwordErrors.forEach(function(msg) { %><li><%= msg %></li><% }); %>
    </ul>
  <% } %>

  <form action="/users/me/password" method="POST" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label for="currentPassword">현재 비밀번호</label>
    <input type="password" id="currentPassword" name="currentPassword" required autocomplete="current-password">

    <label for="newPassword">새 비밀번호</label>
    <input type="password" id="newPassword" name="newPassword" required autocomplete="new-password">

    <label for="newPasswordConfirm">새 비밀번호 확인</label>
    <input type="password" id="newPasswordConfirm" name="newPasswordConfirm" required autocomplete="new-password">

    <button type="submit">변경하기</button>
  </form>
</section>
<%- include('../partials/footer') %>
