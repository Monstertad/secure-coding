<%# 송금 페이지 %>
<%- include('../partials/header') %>
<section class="auth-form">
  <h1>송금</h1>

  <% if (sent) { %>
    <p class="success-message">송금이 완료되었습니다.</p>
  <% } %>

  <% if (errors && errors.length) { %>
    <ul class="error-list">
      <% errors.forEach(function(msg) { %><li><%= msg %></li><% }); %>
    </ul>
  <% } %>

  <% if (!history) { %>
    <form action="/transfer/send" method="POST" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="receiverId">받는 사람 회원 번호</label>
      <input type="number" id="receiverId" name="receiverId" value="<%= values.receiverId %>" min="1" required>

      <label for="amount">금액 (원)</label>
      <input type="number" id="amount" name="amount" value="<%= values.amount %>" min="0.01" step="0.01" max="100000000" required>

      <button type="submit">송금하기</button>
    </form>
    <p><a href="/transfer/history">송금 내역 보기</a></p>
  <% } else { %>
    <% if (history.length === 0) { %>
      <p>송금 내역이 없습니다.</p>
    <% } else { %>
      <table class="report-table">
        <thead>
          <tr><th>구분</th><th>상대</th><th>금액</th><th>상품연계</th><th>일시</th></tr>
        </thead>
        <tbody>
          <% history.forEach(function(t) { %>
            <% var isSender = t.sender_id === currentUser.id; %>
            <tr>
              <td><%= isSender ? '보냄' : '받음' %></td>
              <td><%= isSender ? t.receiver_username : t.sender_username %></td>
              <td><%= Number(t.amount).toLocaleString('ko-KR') %>원</td>
              <td><%= t.product_id ? ('상품 #' + t.product_id) : '-' %></td>
              <td><%= new Date(t.created_at).toLocaleString('ko-KR') %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
    <p><a href="/transfer/send">송금하기</a></p>
  <% } %>
</section>
<%- include('../partials/footer') %>
