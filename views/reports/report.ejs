<%# 신고하기 페이지 %>
<%- include('../partials/header') %>
<section class="auth-form">
  <h1>신고</h1>

  <% if (submitted) { %>
    <p class="success-message">신고가 접수되었습니다.</p>
  <% } %>

  <% if (errors && errors.length) { %>
    <ul class="error-list">
      <% errors.forEach(function(msg) { %><li><%= msg %></li><% }); %>
    </ul>
  <% } %>

  <% if (!myReports) { %>
    <form action="/reports" method="POST" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="targetType">신고 대상 유형</label>
      <select id="targetType" name="targetType" required>
        <option value="USER" <%= values.targetType === 'USER' ? 'selected' : '' %>>사용자</option>
        <option value="PRODUCT" <%= values.targetType === 'PRODUCT' ? 'selected' : '' %>>상품</option>
        <option value="MESSAGE" <%= values.targetType === 'MESSAGE' ? 'selected' : '' %>>채팅 메시지</option>
      </select>

      <label for="targetId">대상 번호</label>
      <input type="number" id="targetId" name="targetId" value="<%= values.targetId %>" min="1" required>

      <label for="reason">신고 사유</label>
      <textarea id="reason" name="reason" maxlength="1000" rows="5" required><%= values.reason %></textarea>

      <button type="submit">신고 제출</button>
    </form>
    <p><a href="/reports/my">내 신고 내역 보기</a></p>
  <% } else { %>
    <% if (myReports.length === 0) { %>
      <p>제출한 신고 내역이 없습니다.</p>
    <% } else { %>
      <table class="report-table">
        <thead>
          <tr><th>대상</th><th>사유</th><th>상태</th><th>제출일</th></tr>
        </thead>
        <tbody>
          <% myReports.forEach(function(r) { %>
            <tr>
              <td><%= r.target_type %> #<%= r.target_id %></td>
              <td><%= r.reason %></td>
              <td>
                <%= r.status === 'WAITING' ? '대기중' : (r.status === 'APPROVED' ? '승인됨' : '반려됨') %>
              </td>
              <td><%= new Date(r.created_at).toLocaleDateString('ko-KR') %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
    <p><a href="/reports/new">새 신고 작성</a></p>
  <% } %>
</section>
<%- include('../partials/footer') %>
